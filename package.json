{
  "name": "daily-form-system",
  "version": "3.0.0",
  "description": "每日数据填报系统（Vue 3 重构版）",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "type-check": "vue-tsc --noEmit",
    "server": "node server.js",
    "start": "npm run build && node server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "review": "npm run type-check && npm run lint && npm run test",
    "snapshot": "node scripts/snapshot-all.js create",
    "snapshot:list": "node scripts/snapshot-all.js list",
    "snapshot:restore": "node scripts/snapshot-all.js restore"
  },
  "dependencies": {
    "axios": "^1.7.0",
    "bcrypt": "^6.0.0",
    "express": "^5.2.1",
    "naive-ui": "^2.39.0",
    "pinia": "^2.2.0",
    "sql.js": "^1.14.1",
    "vue": "^3.5.0",
    "vue-router": "^4.4.0",
    "xlsx": "^0.18.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "@vitejs/plugin-vue": "^5.1.0",
    "@vue/test-utils": "^2.4.10",
    "eslint": "^10.3.0",
    "eslint-plugin-vue": "^10.9.0",
    "happy-dom": "^20.9.0",
    "sass": "^1.77.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.59.2",
    "vite": "^5.4.0",
    "vitest": "^4.1.5",
    "vue-tsc": "^2.1.0"
  }
}
